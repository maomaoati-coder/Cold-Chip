 · 动态应力与极端环境仿真  [v3 流片前终版]
//  修复记录：
//    v2 → v3: eff_pass timeout 消除
//             · pass_cnt 清零加滞后保护（连续4周期 !resonance 才清零）
//             · tb: wait(resonance) / wait(eff_pass) 独立超时窗口
//             · 全局超时扩展至 2_000_000 ns
// ============================================================
`timescale 1ns / 1ps

// ── env_model ────────────────────────────────────────────────
module env_model (
    input  wire       clk, rst_n,
    input  wire [1:0] env_mode,
    input  wire [7:0] heat_inject,
    output reg  [7:0] chip_temp,
    output reg  [3:0] heat_level,
    output reg        liquid_ok
);
    reg [7:0] acc [0:3];
    reg [7:0] base_temp;
    reg [3:0] cool_rate;
    integer i;
    wire [7:0] hd = {4'b0, heat_inject[3:0]};

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            for(i=0;i<4;i=i+1) acc[i] <= 0;
            chip_temp <= 8'd50; heat_level <= 0; liquid_ok <= 1;
        end else begin
            case(env_mode)
                2'b00: begin base_temp <= 8'd50;  cool_rate <= 8; liquid_ok <= 1; end
                2'b01: begin base_temp <= 8'd10;  cool_rate <= 4; liquid_ok <= 1; end
                2'b10: begin base_temp <= 8'd150; cool_rate <= 2; liquid_ok <= 1; end
                2'b11: begin base_temp <= 8'd50;  cool_rate <= 1; liquid_ok <= 0; end
            endcase
            for(i=0;i<4;i=i+1)
                acc[i] <= (acc[i] > cool_rate) ? acc[i] - cool_rate : 0;
            if (heat_inject[7]) begin
                case(heat_inject[5:4])
                    2'b00: acc[0] <= ((acc[0]+hd)>255) ? 255 : (acc[0]+hd);
                    2'b01: acc[1] <= ((acc[1]+hd)>255) ? 255 : (acc[1]+hd);
                    2'b10: acc[2] <= ((acc[2]+hd)>255) ? 255 : (acc[2]+hd);
                    2'b11: acc[3] <= ((acc[3]+hd)>255) ? 255 : (acc[3]+hd);
                endcase
            end
            heat_level[0] <= (acc[0] >= 200) ? 1 : 0;
            heat_level[1] <= (acc[1] >= 200) ? 1 : 0;
            heat_level[2] <= (acc[2] >= 200) ? 1 : 0;
            heat_level[3] <= (acc[3] >= 200) ? 1 : 0;
            chip_temp <= base_temp
                       + acc[0][7:4] + acc[1][7:4]
                       + acc[2][7:4] + acc[3][7:4];
        end
    end
endmodule

// ── stress_clk ───────────────────────────────────────────────
module stress_clk (
    input  wire       clk_ref, rst_n, resonance,
    input  wire [3:0] island_online,
    input  wire       liquid_ok,
    input  wire [7:0] chip_temp,
    output reg        clk_out,
    output reg  [1:0] clk_mode
);
    reg [3:0] div_cnt, div_max;
    wire [3:0] cnt = island_online[0] + island_online[1]
                   + island_online[2] + island_online[3];

    always @(posedge clk_ref or negedge rst_n) begin
        if (!rst_n) begin
            div_cnt <= 0; div_max <= 4; clk_out <= 0; clk_mode <= 0;
        end else begin
            if      (!liquid_ok || chip_temp > 200) begin div_max <= 4'd8; clk_mode <= 2'b00; end
            else if (chip_temp > 150)               begin div_max <= 4'd4; clk_mode <= 2'b01; end
            else if (resonance && cnt == 4)         begin div_max <= 4'd1; clk_mode <= 2'b11; end
            else if (cnt == 4)                      begin div_max <= 4'd2; clk_mode <= 2'b10; end
            else if (cnt >= 3)                      begin div_max <= 4'd3; clk_mode <= 2'b01; end
            else                                    begin div_max <= 4'd4; clk_mode <= 2'b00; end
            if (div_cnt >= div_max) begin div_cnt <= 0; clk_out <= ~clk_out; end
            else div_cnt <= div_cnt + 1;
        end
    end
endmodule

// ── stress_island ────────────────────────────────────────────
module stress_island (
    input  wire clk, rst_n, heat_level, resonance, liquid_ok,
    output reg  island_online, island_sleep, island_degraded
);
    reg [1:0] state;
    reg [5:0] cnt;
    localparam B=0, O=1, S=2, R=3;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            state <= B; cnt <= 0;
            island_online <= 0; island_sleep <= 0; island_degraded <= 0;
        end else begin
            island_degraded <= (!liquid_ok && state == O) ? 1 : 0;
            case(state)
                B: begin
                    island_online <= 0; island_sleep <= 0;
                    if (cnt >= 4) begin state <= O; cnt <= 0; end
                    else cnt <= cnt + 1;
                end
                O: begin
                    island_online <= 1; island_sleep <= 0;
                    if (heat_level) begin
                        if (!liquid_ok) begin
                            if (cnt >= 4) begin state <= S; cnt <= 0; end
                            else cnt <= cnt + 1;
                        end else state <= S;
                    end
                end
                S: begin
                    island_online <= 0; island_sleep <= 1;
                    if (!heat_level) begin state <= R; cnt <= 0; end
                end
                R: begin
                    island_online <= 0; island_sleep <= 0;
                    if (cnt >= (liquid_ok ? 6'd8 : 6'd16)) begin
                        state <= O; cnt <= 0;
                    end else cnt <= cnt + 1;
                end
            endcase
        end
    end
endmodule

// ── stress_resonance ─────────────────────────────────────────
module stress_resonance (
    input  wire       clk, rst_n, res_lock,
    input  wire [3:0] island_online,
    input  wire [7:0] chip_temp,
    input  wire       liquid_ok,
    output reg        resonance
);
    reg [4:0] cnt;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin resonance <= 0; cnt <= 0; end
        else if (!liquid_ok || chip_temp > 200) begin resonance <= 0; cnt <= 0; end
        else if (island_online == 4'hF && res_lock) begin
            if (cnt >= 8) resonance <= 1; else cnt <= cnt + 1;
        end else begin resonance <= 0; cnt <= 0; end
    end
endmodule

// ── stress_eff ───────────────────────────────────────────────
// v3 修复：pass_cnt 清零加滞后保护
//   · resonance glitch 不再瞬间复位计数器
//   · 连续 4 个周期 !resonance 才真正清零（去抖）
module stress_eff (
    input  wire       clk, rst_n, resonance,
    input  wire [3:0] island_online, island_degraded,
    input  wire [7:0] chip_temp,
    input  wire       liquid_ok,
    output reg        eff_pass, eff_degraded, zero_heat_ok,
    output reg [15:0] eff_bp
);
    reg [6:0]  pass_cnt;
    reg [2:0]  res_off_cnt;   // 滞后去抖计数器

    wire [3:0] ocnt = island_online[0] + island_online[1]
                    + island_online[2] + island_online[3];

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            eff_pass    <= 0; eff_degraded <= 0;
            zero_heat_ok<= 0; eff_bp <= 0;
            pass_cnt    <= 0; res_off_cnt <= 0;
        end else begin
            // ── 温度指示 ──────────────────────────────────────
            zero_heat_ok <= (chip_temp <= 70) ? 1 : 0;

            // ── EFF 基点计算 ──────────────────────────────────
            if      (resonance && liquid_ok)  eff_bp <= 16'd9804;
            else if (resonance && !liquid_ok) eff_bp <= 16'd8000;
            else if (ocnt == 4 && liquid_ok)  eff_bp <= 16'd8333;
            else if (ocnt >= 3)               eff_bp <= 16'd7500;
            else if (ocnt >= 2)               eff_bp <= 16'd6000;
            else                              eff_bp <= 16'd3000;

            // ── eff_pass 建立逻辑（带滞后去抖）─────────────────
            if (resonance && liquid_ok && chip_temp <= 120) begin
                res_off_cnt <= 0;                          // 共振有效，清去抖计数
                if (pass_cnt >= 7'd16) eff_pass <= 1;
                else                   pass_cnt <= pass_cnt + 1;
            end else begin
                // !resonance 需连续 4 周期才清零，避免瞬态 glitch 复位
                if (res_off_cnt >= 3'd4) begin
                    pass_cnt <= 0;
                    eff_pass <= 0;
                end else begin
                    res_off_cnt <= res_off_cnt + 1;
                end
            end

            eff_degraded <= (eff_bp >= 16'd8000) ? 1 : 0;
        end
    end
endmodule

// ── stress_lfsr ──────────────────────────────────────────────
module stress_lfsr (
    input  wire clk, rst_n, enable,
    output reg [7:0] heat_inject
);
    reg [15:0] lfsr;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin lfsr <= 16'hACE1; heat_inject <= 0; end
        else if (enable) begin
            lfsr        <= {lfsr[14:0], lfsr[15]^lfsr[14]^lfsr[12]^lfsr[3]};
            heat_inject <= {1'b1, 1'b0, lfsr[5:4], lfsr[3:0]};
        end else heat_inject <= 0;
    end
endmodule

// ── cold_chip_stress_top ─────────────────────────────────────
module cold_chip_stress_top (
    input  wire        clk_ref, rst_n,
    input  wire [1:0]  env_mode,
    input  wire [7:0]  heat_inject,
    input  wire        res_lock,
    output wire [3:0]  island_online, island_sleep, island_degraded,
    output wire        resonance, liquid_ok,
    output wire [7:0]  chip_temp,
    output wire        eff_pass, eff_degraded, zero_heat_ok,
    output wire [15:0] eff_bp,
    output wire [1:0]  clk_mode
);
    wire [3:0] heat_level;
    wire clk_a;   // 分频时钟，仅供观测/clk_mode输出，不驱动逻辑

    env_model u_env(
        .clk(clk_ref), .rst_n(rst_n), .env_mode(env_mode),
        .heat_inject(heat_inject), .chip_temp(chip_temp),
        .heat_level(heat_level), .liquid_ok(liquid_ok));

    stress_clk u_clk(
        .clk_ref(clk_ref), .rst_n(rst_n), .resonance(resonance),
        .island_online(island_online), .liquid_ok(liquid_ok),
        .chip_temp(chip_temp), .clk_out(clk_a), .clk_mode(clk_mode));

    genvar g;
    generate for (g = 0; g < 4; g = g+1) begin : isl
        stress_island u_i(
            .clk(clk_ref), .rst_n(rst_n), .heat_level(heat_level[g]),
            .resonance(resonance), .liquid_ok(liquid_ok),
            .island_online(island_online[g]),
            .island_sleep(island_sleep[g]),
            .island_degraded(island_degraded[g]));
    end endgenerate

    stress_resonance u_res(
        .clk(clk_ref), .rst_n(rst_n), .res_lock(res_lock),
        .island_online(island_online), .chip_temp(chip_temp),
        .liquid_ok(liquid_ok), .resonance(resonance));

    stress_eff u_eff(
        .clk(clk_ref), .rst_n(rst_n), .resonance(resonance),
        .island_online(island_online), .island_degraded(island_degraded),
        .chip_temp(chip_temp), .liquid_ok(liquid_ok),
        .eff_pass(eff_pass), .eff_degraded(eff_degraded),
        .zero_heat_ok(zero_heat_ok), .eff_bp(eff_bp));
endmodule

